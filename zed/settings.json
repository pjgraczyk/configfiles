{
  "language_models": {
    "lmstudio": {
      "api_url": "http://192.168.0.77:1234/api/v1"
    },
    "ollama": {
      "api_url": "http://localhost:11434"
    }
  },
  "restore_on_startup": "launchpad",
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "ui_font_family": ".SystemUIFont",
  "outline_panel": {
    "indent_size": 10.0
  },
  "agent": {
    "default_profile": "minimal",
    "flexible": false,
    "max_content_width": 360.0,
    "default_width": 360.0,
    "inline_assistant_model": {
      "provider": "zed.dev",
      "model": "claude-sonnet-4-6",
      "enable_thinking": false
    },
    "default_model": {
      "provider": "zed.dev",
      "model": "gpt-5-nano",
      "enable_thinking": false
    },
    "favorite_models": [
      {
        "provider": "zed.dev",
        "model": "gpt-5-nano",
        "enable_thinking": false
      }
    ],
    "model_parameters": []
  },
  "use_system_window_tabs": true,
  "tab_bar": {
    "show_pinned_tabs_in_separate_row": true,
  },
  "tabs": {
    "git_status": true,
    "file_icons": true,
  },
  "title_bar": {
    "show_menus": true,
    "show_branch_status_icon": true,
  },
  "edit_predictions": {
    "mode": "subtle",
  },
  "proxy": "",
  "buffer_font_family": "FiraCode Nerd Font Mono",
  "buffer_line_height": "standard",
  "buffer_font_features": {
    "calt": true,
    "liga": true,
  },
  "use_system_path_prompts": false,
  "use_system_prompts": false,
  "project_panel": {
    "indent_size": 10.0,
    "bold_folder_labels": true,
  },
  "ui_font_weight": 400.0,
  "buffer_font_weight": 400.0,
  "icon_theme": "Min Icons",
  "languages": {
    "C": {
      "prettier": {
        "allowed": true,
      },
      "inlay_hints": {
        "enabled": true,
      },
    },
    "Python": {
      "language_servers": ["!basedpyright", "ty", "ruff"],
    },
  },
  "gutter": {
    "runnables": true,
  },
  "relative_line_numbers": "enabled",
  "sticky_scroll": {
    "enabled": true,
  },
  "which_key": {
    "enabled": true,
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "terminal": {
    "toolbar": {
      "breadcrumbs": true,
    },
    "default_width": 640.0,
    "copy_on_select": true,
    "option_as_meta": true,
    "blinking": "on",
    "cursor_shape": "bar",
    "font_family": "FiraCode Nerd Font",
    "font_weight": 400.0,
    "font_features": {
      "calt": true,
      "liga": true,
    },
    "show_count_badge": true,
    "flexible": true,
  },
  "ssh_connections": [
    {
      "host": "hetzner-tailscale",
      "args": [],
      "projects": [
        {
          "paths": ["/home/pjgraczyk"],
        },
        {
          "paths": ["/home/pjgraczyk/projects/c_intro"],
        },
      ],
      "nickname": "hetzner",
    },
  ],
  "helix_mode": true,
  "agent_servers": {
    "opencode": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry",
    },
    "mistral-vibe": {
      "favorite_config_option_values": {
        "mode": ["auto-approve"],
        "thinking": ["max"],
      },
      "type": "registry",
    },
    "github-copilot-cli": {
      "type": "registry",
    },
    "gemini": {
      "type": "registry",
    },
  },
  "ui_font_size": 13.0,
  "buffer_font_size": 13.0,
  "theme": "Min Dark (Solid)",
}
